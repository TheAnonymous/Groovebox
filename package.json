{
  "name": "groovebox",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "audio:lab": "vite --config vite.audio-lab.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:audio": "playwright test --config playwright.audio.config.ts",
    "test:all": "npm test && npm run build && npm run test:e2e && npm run test:audio"
  },
  "dependencies": {
    "tone": "15.5.27"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.0",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
